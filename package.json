{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "clean": "turbo run clean",
    "clean:all": "turbo run clean:all && rm -rf .husky .turbo bun.lock node_modules",
    "prepare": "husky",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "biome check && turbo run lint",
    "lint:fix": "biome check --write --unsafe && turbo run lint -- --fix",
    "format": "biome format --write",
    "format:check": "biome check --write",
    "types:check": "turbo run types:check",
    "version": "changeset version && bun update",
    "release": "bash ./scripts/publish.sh"
  },
  "keywords": [],
  "author": "Lukman Aviccena <lukman@pelatform.com>",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@pelatform/biome-config": "^0.1.6",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "commitlint-plugin-function-rules": "^4.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "turbo": "2.9.6",
    "typescript": "catalog:"
  },
  "workspaces": {
    "packages": [
      "packages/**",
      "apps/**"
    ],
    "catalog": {
      "recharts": "2.15.1",
      "typescript": "5.9.3"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": "biome check --write --no-errors-on-unmatched",
    "*.{md,yml,yaml}": "prettier --write",
    "*.{json,jsonc,html}": "biome format --write --no-errors-on-unmatched"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.13"
}
