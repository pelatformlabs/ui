{
  "name": "@pelatform/ui.components",
  "version": "0.1.0",
  "description": "Default components of the Pelatform UI Library.",
  "author": "Pelatform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./css": "./dist/style.css",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./animation": {
      "types": "./dist/animation.d.ts",
      "default": "./dist/animation.js"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "default": "./dist/base.js"
    },
    "./radix": {
      "types": "./dist/radix.d.ts",
      "default": "./dist/radix.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "rimraf .turbo dist node_modules",
    "dev": "tsup --watch",
    "build": "tsup && cp src/style.css dist/style.css",
    "types:check": "tsc --noEmit"
  },
  "repository": "github:pelatformlabs/ui",
  "homepage": "https://github.com/pelatformlabs/ui",
  "bugs": {
    "url": "https://github.com/pelatformlabs/ui/issues"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "pelatform",
    "ui",
    "react",
    "nextjs",
    "vite",
    "components",
    "radix ui",
    "base ui",
    "animation"
  ],
  "devDependencies": {
    "@base-ui/react": "^1.2.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headless-tree/core": "^1.6.3",
    "@pelatform/tsconfig": "^0.1.4",
    "@tanstack/react-table": "^8.21.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-phone-number-input": "^3.4.16",
    "react-resizable-panels": "^4.7.0",
    "recharts": "catalog:",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.2.0",
    "@dnd-kit/core": ">=6.3.0",
    "@dnd-kit/modifiers": ">=9.0.0",
    "@dnd-kit/sortable": ">=10.0.0",
    "@dnd-kit/utilities": ">=3.2.0",
    "@headless-tree/core": ">=1.6.0",
    "@tanstack/react-table": ">=8.21.0",
    "class-variance-authority": ">=0.7.0",
    "clsx": ">=2.1.0",
    "cmdk": ">=1.1.0",
    "date-fns": ">=4.1.0",
    "embla-carousel-react": ">=8.6.0",
    "input-otp": ">=1.4.0",
    "lucide-react": ">=0.575.0",
    "motion": ">=12.30.0",
    "next-themes": ">=0.4.6",
    "radix-ui": ">=1.4.0",
    "react": ">=18.0.0 || >=19.0.0-rc.0",
    "react-dom": ">=18.0.0 || >=19.0.0-rc.0",
    "react-day-picker": ">=9.13.0",
    "react-phone-number-input": ">=3.4.0",
    "react-resizable-panels": ">=4.6.0",
    "recharts": "2.15.1",
    "sonner": ">=2.0.0",
    "tailwind-merge": ">=3.5.0",
    "tsup": ">=8.5.0",
    "typescript": ">=5.9.0",
    "vaul": ">=1.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": "biome check --write --no-errors-on-unmatched",
    "*.{md,yml,yaml}": "prettier --write",
    "*.{json,jsonc,html}": "biome format --write --no-errors-on-unmatched"
  }
}
