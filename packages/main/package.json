{
  "name": "pelatform-ui",
  "version": "1.2.7",
  "description": "A Modern and Minimal React UI Library built with TailwindCSS.",
  "author": "Pelatform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./css": "./css/theme.css",
    "./css/*": "./css/styles/*.css",
    "./css/components/*": "./css/components/*.css",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./animation": {
      "types": "./dist/animation.d.ts",
      "default": "./dist/animation.js"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "default": "./dist/base.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "default": "./dist/components.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "default": "./dist/hooks.js"
    },
    "./radix": {
      "types": "./dist/radix.d.ts",
      "default": "./dist/radix.js"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "default": "./dist/utils.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "clean:all": "rimraf .turbo dist node_modules",
    "dev": "tsup --watch",
    "build": "tsup",
    "types:check": "tsc --noEmit"
  },
  "repository": "github:pelatformlabs/ui",
  "homepage": "https://github.com/pelatformlabs/ui",
  "bugs": {
    "url": "https://github.com/pelatformlabs/ui/issues"
  },
  "files": [
    "css",
    "dist"
  ],
  "keywords": [
    "pelatform",
    "ui",
    "react",
    "nextjs",
    "vite",
    "tailwindcss",
    "shadcn",
    "radix ui",
    "base ui",
    "components",
    "animation"
  ],
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@pelatform/tsconfig": "^0.1.4",
    "@pelatform/ui.components": "workspace:*",
    "@pelatform/ui.hook": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "@types/react": "^19.2.14",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@base-ui/react": ">=1.2.0",
    "@dnd-kit/core": ">=6.3.0",
    "@dnd-kit/modifiers": ">=9.0.0",
    "@dnd-kit/sortable": ">=10.0.0",
    "@dnd-kit/utilities": ">=3.2.0",
    "@headless-tree/core": ">=1.6.0",
    "@pelatform/ui.components": ">=0.1.0",
    "@pelatform/ui.hook": ">=0.2.0",
    "@tanstack/react-query": ">=5.90.0",
    "@tanstack/react-table": ">=8.21.0",
    "class-variance-authority": ">=0.7.0",
    "clsx": ">=2.1.0",
    "cmdk": ">=1.1.0",
    "date-fns": ">=4.1.0",
    "embla-carousel-react": ">=8.6.0",
    "input-otp": ">=1.4.0",
    "lucide-react": ">=0.575.0",
    "motion": ">=12.30.0",
    "next-themes": ">=0.4.6",
    "radix-ui": ">=1.4.0",
    "react": ">=18.0.0 || >=19.0.0-rc.0",
    "react-day-picker": ">=9.10.0",
    "react-dom": ">=18.0.0 || >=19.0.0-rc.0",
    "react-phone-number-input": ">=3.4.0",
    "react-resizable-panels": ">=4.7.0",
    "recharts": "2.15.1",
    "sonner": ">=2.0.0",
    "tailwind-merge": ">=3.5.0",
    "vaul": ">=1.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": "biome check --write --no-errors-on-unmatched",
    "*.{md,yml,yaml}": "prettier --write",
    "*.{json,jsonc,html}": "biome format --write --no-errors-on-unmatched"
  }
}
